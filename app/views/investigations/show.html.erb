<% content_for :title, "Investigation Home" %>

<div class="usa-app-shell">
  <header class="usa-app-header">
    <div class="flex items-center gap-6">
      <h1 class="usa-app-title">Investigation Home</h1>
      <span class="text-[12px] uppercase tracking-wide text-slate-500">
        <%= @investigation.name.truncate(60) %>
      </span>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "View Network Graph", graph_investigation_path(@investigation), target: "_blank", class: "usa-btn-outline" %>
      <%= link_to "Produce Report", report_investigation_path(@investigation), target: "_blank", class: "usa-btn-secondary" %>
      <button type="button" class="usa-btn-outline">Export Data</button>
      <button type="button" class="usa-btn-outline">Publish to Spoke</button>
    </div>
  </header>

  <main class="mx-auto w-full max-w-6xl px-8 py-8">
    <section class="usa-summary-box">
      <h2 class="usa-summary-title">High Level Summary</h2>
      <ul class="usa-summary-list">
        <% @demo[:summary].each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
    </section>

    <nav class="usa-tabbar mt-8" aria-label="Investigation views">
      <% [
            ["entities",  "Context Entities"],
            ["selectors", "Selectors"],
            ["cases",     "Related Cases"],
            ["patterns",  "Patterns of Behavior"]
         ].each do |slug, label| %>
        <%= link_to label,
              investigation_path(@investigation, tab: slug),
              class: "usa-tablink #{'usa-tablink-active' if @tab == slug}" %>
      <% end %>
    </nav>

    <div class="mt-6 space-y-2">
      <% case @tab %>
      <% when "entities" %>
        <% @demo[:entities].each do |row| %>
          <div class="usa-row <%= 'usa-row-mute' if row[:status] == 'unmatched' %>">
            <div class="col-span-3 flex items-center gap-2 pl-2 flex-wrap">
              <span class="font-bold text-slate-900"><%= row[:name] %></span>
              <span class="usa-badge <%= row[:status] == 'matched' ? 'usa-badge-matched' : 'usa-badge-unmatched' %>">
                <%= row[:status] %>
              </span>
              <% if row[:crustdata_id] %>
                <span class="usa-tag-dark">Crustdata ID <%= row[:crustdata_id] %></span>
              <% end %>
            </div>
            <div class="col-span-2"><%= row[:phone] %></div>
            <div class="col-span-3 truncate">
              <% if row[:linkedin_url] %>
                <%= link_to "linkedin.com/company/rc-kairos", row[:linkedin_url], target: "_blank", class: "underline text-blue-700" %>
              <% else %>
                <%= row[:email] %>
              <% end %>
            </div>
            <div class="col-span-2 flex items-center gap-2 flex-wrap">
              <% if row[:headquarters] %>
                <span class="text-[12px] text-slate-700">📍 <%= row[:headquarters].split(",").first %>, MX</span>
              <% else %>
                <span aria-hidden="true">👤</span>
                <span><%= row[:personnel] %></span>
              <% end %>
            </div>
            <div class="col-span-2 flex justify-end">
              <button type="button" class="usa-view-btn">View Profile</button>
            </div>
          </div>
        <% end %>

      <% when "selectors" %>
        <% @demo[:selectors].each do |row| %>
          <div class="usa-row-plain">
            <div class="col-span-3 pl-2 font-bold text-slate-900"><%= row[:kind] %></div>
            <div class="col-span-4 text-slate-700">Last Updated Date: <%= row[:last_updated] %></div>
            <div class="col-span-3 flex items-center gap-2 text-slate-700">
              <span>Other fields available</span>
              <span class="usa-count-chip"><%= row[:other_fields] %></span>
            </div>
            <div class="col-span-2 flex justify-end pr-2">
              <button type="button" class="usa-row-action">More Details</button>
            </div>
          </div>
        <% end %>

      <% when "cases" %>
        <% @demo[:cases].each do |row| %>
          <div class="usa-row-plain">
            <div class="col-span-3 flex items-center gap-2 pl-2">
              <span class="font-bold text-slate-900"><%= row[:name] %></span>
              <span class="usa-tag-dark"><%= row[:office] %></span>
            </div>
            <div class="col-span-3 flex items-center gap-2 text-slate-700">
              <span>Linked selectors</span>
              <span class="usa-count-chip"><%= row[:linked_selectors] %></span>
            </div>
            <div class="col-span-3 text-slate-700">Case Last Updated: <%= row[:last_updated] %></div>
            <div class="col-span-2 flex items-center gap-2 text-slate-700">
              <span aria-hidden="true">👤</span>
              <span><%= row[:contact] %></span>
            </div>
            <div class="col-span-1 flex justify-end pr-2">
              <button type="button" class="usa-row-action">View Investigation <span aria-hidden="true">›</span></button>
            </div>
          </div>
        <% end %>

      <% when "patterns" %>
        <% @demo[:patterns].each do |row| %>
          <div class="usa-row-plain">
            <div class="col-span-4 pl-2 font-bold text-slate-900"><%= row[:description] %></div>
            <div class="col-span-3 text-slate-700">First Seen: <%= row[:first_seen] %></div>
            <div class="col-span-3 flex items-center gap-2 text-slate-700">
              <span>Linked selectors</span>
              <span class="usa-count-chip"><%= row[:linked_selectors] %></span>
            </div>
            <div class="col-span-2 flex justify-end pr-2">
              <button type="button" class="usa-row-action">See Linked Entity Network <span aria-hidden="true">›</span></button>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <footer class="mt-10 flex items-center justify-between text-[12px] text-slate-500">
      <div>
        <%= @investigation.sources.count %> sources ingested ·
        <%= @investigation.scrapers.count %> scrapers configured ·
        updated <%= time_ago_in_words(@investigation.updated_at) %> ago
      </div>
      <%= link_to "← Start a new investigation", new_investigation_path, class: "underline text-blue-700" %>
    </footer>
  </main>
</div>
