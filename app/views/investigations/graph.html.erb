<% content_for :title, "Network Graph — #{@investigation.name}" %>
<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/vis-network@9.1.9/styles/vis-network.min.css">
  <style>
    .graph-shell { height: calc(100vh - 56px); display: grid; grid-template-columns: 1fr 380px; }
    @media (max-width: 900px) { .graph-shell { grid-template-columns: 1fr; } #graph-panel { display: none; } }
    #graph-canvas { background: #f8fafc; border-right: 1px solid #e2e8f0; }
    #graph-panel { background: white; border-left: 1px solid #e2e8f0; overflow-y: auto; padding: 1.25rem 1.25rem 4rem; font-family: "Public Sans", sans-serif; }
    .legend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }
    .panel-section { border-top: 1px solid #e2e8f0; padding-top: 1rem; margin-top: 1rem; }
    .panel-section:first-of-type { border-top: 0; padding-top: 0; margin-top: 0; }
    .panel-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #475569; }
    .panel-h2 { font-size: 18px; font-weight: 700; color: #0f172a; margin-top: 4px; }
    .panel-relationship { font-family: "Roboto Mono", monospace; font-size: 13px; color: #1e293b; background: #f1f5f9; padding: 6px 10px; border-radius: 4px; display: inline-block; }
    .panel-textarea { width: 100%; min-height: 96px; border: 1px solid #cbd5e1; border-radius: 4px; padding: 8px 10px; font-size: 13px; font-family: "Public Sans", sans-serif; }
    .panel-input { width: 100%; border: 1px solid #cbd5e1; border-radius: 4px; padding: 6px 8px; font-size: 13px; }
    .panel-thumb { display: block; width: 100%; max-height: 220px; object-fit: contain; border: 1px solid #e2e8f0; border-radius: 4px; margin-top: 8px; background: #f8fafc; }
    .panel-empty { color: #64748b; font-size: 13px; line-height: 1.5; }
    .pill { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 999px; background: #e2e8f0; color: #1e293b; font-size: 11px; font-weight: 600; }
    .pill-saved { background: #dcfce7; color: #14532d; }
    .att-row { margin-top: 0.5rem; }
    .att-cap { font-size: 11px; color: #64748b; margin-top: 4px; display: flex; align-items: center; justify-content: space-between; }
    .att-remove { color: #dc2626; background: none; border: 0; cursor: pointer; padding: 0; font-size: 11px; }
    .att-remove:hover { text-decoration: underline; }
  </style>
<% end %>

<div class="no-print sticky top-0 z-10 flex items-center justify-between border-b border-slate-200 bg-white px-6 py-3">
  <div class="flex items-center gap-4">
    <span class="text-[12px] uppercase tracking-widest text-slate-500 font-mono">Network Graph</span>
    <span class="text-[13px] text-slate-700"><%= @investigation.name.truncate(60) %></span>
  </div>
  <div class="flex items-center gap-2">
    <button id="graph-fit"     class="usa-btn-outline">Fit</button>
    <button id="graph-physics" class="usa-btn-outline">Pause physics</button>
    <button id="graph-clear"   class="usa-btn-outline">Clear annotations</button>
    <%= link_to "← Back to Investigation", investigation_path(@investigation), class: "usa-btn-outline" %>
  </div>
</div>

<div class="graph-shell">
  <div id="graph-canvas"></div>
  <aside id="graph-panel">
    <div id="graph-empty">
      <div class="panel-label">Network ontology</div>
      <h2 class="panel-h2">RC Kairos cluster</h2>
      <p class="panel-empty mt-2">
        Click any <strong>node</strong> or <strong>edge</strong> to inspect it. You can leave notes,
        attach images, and the annotations will persist on this device via local storage.
      </p>

      <div class="panel-section">
        <div class="panel-label mb-2">Legend</div>
        <ul class="space-y-1 text-[13px] text-slate-700">
          <li><span class="legend-dot" style="background:#f59e0b"></span> Company / broker</li>
          <li><span class="legend-dot" style="background:#7c3aed"></span> Marketplace / brand</li>
          <li><span class="legend-dot" style="background:#0ea5e9"></span> Supplier</li>
          <li><span class="legend-dot" style="background:#22c55e"></span> Chemical</li>
          <li><span class="legend-dot" style="background:#64748b"></span> Location</li>
          <li><span class="legend-dot" style="background:#14b8a6"></span> Encrypted handle</li>
          <li><span class="legend-dot" style="background:#3b82f6"></span> Communication selector</li>
          <li><span class="legend-dot" style="background:#ef4444"></span> Case</li>
          <li><span class="legend-dot" style="background:#0f172a"></span> Person</li>
        </ul>
      </div>

      <div class="panel-section">
        <div class="panel-label mb-2">Stats</div>
        <p class="text-[13px] text-slate-700"><%= @graph[:nodes].size %> nodes · <%= @graph[:edges].size %> typed edges</p>
        <p class="text-[12px] text-slate-500 mt-1">Drag nodes to rearrange. Scroll to zoom.</p>
      </div>
    </div>
    <div id="graph-detail" style="display:none"></div>
  </aside>
</div>

<script src="https://unpkg.com/vis-network@9.1.9/standalone/umd/vis-network.min.js"></script>
<script>
  (function () {
    var INV_ID = <%= @investigation.id %>;
    var STORAGE_KEY = "holocron-graph-" + INV_ID;

    var GROUP_STYLES = {
      company:     { color: "#f59e0b", shape: "dot",        size: 26 },
      broker:      { color: "#f59e0b", shape: "dot",        size: 22 },
      marketplace: { color: "#7c3aed", shape: "square",     size: 20 },
      brand:       { color: "#7c3aed", shape: "square",     size: 22 },
      supplier:    { color: "#0ea5e9", shape: "dot",        size: 20 },
      chemical:    { color: "#22c55e", shape: "triangle",   size: 22 },
      location:    { color: "#64748b", shape: "star",       size: 18 },
      handle:      { color: "#14b8a6", shape: "hexagon",    size: 18 },
      comm:        { color: "#3b82f6", shape: "diamond",    size: 18 },
      case:        { color: "#ef4444", shape: "diamond",    size: 22 },
      person:      { color: "#0f172a", shape: "ellipse",    size: 18 }
    };

    var rawNodes = <%= raw @graph[:nodes].to_json %>;
    var rawEdges = <%= raw @graph[:edges].to_json %>;

    var nodes = new vis.DataSet(rawNodes.map(function (n) {
      var s = GROUP_STYLES[n.group] || { color: "#475569", shape: "dot", size: 18 };
      return Object.assign({}, n, {
        color: { background: s.color, border: "#0f172a", highlight: { background: s.color, border: "#0f172a" } },
        shape: s.shape,
        size: s.size,
        font: { color: "#0f172a", size: 13, face: "Public Sans", strokeWidth: 3, strokeColor: "#fff" }
      });
    }));

    var edges = new vis.DataSet(rawEdges.map(function (e) {
      return Object.assign({}, e, {
        arrows: "to",
        color: { color: "#94a3b8", highlight: "#0f172a" },
        font: { color: "#475569", size: 11, face: "Roboto Mono", strokeWidth: 4, strokeColor: "#fff", align: "middle" },
        smooth: { type: "dynamic" }
      });
    }));

    var network = new vis.Network(
      document.getElementById("graph-canvas"),
      { nodes: nodes, edges: edges },
      {
        interaction: { hover: true, multiselect: false, navigationButtons: false, tooltipDelay: 120 },
        physics: { enabled: true, stabilization: { iterations: 220 }, barnesHut: { gravitationalConstant: -7000, springLength: 140, springConstant: 0.03, damping: 0.4 } },
        nodes: { borderWidth: 1.5, shadow: { enabled: true, size: 4, x: 0, y: 1, color: "rgba(15,23,42,0.10)" } },
        edges: { width: 1.5, hoverWidth: 2.5, selectionWidth: 3 }
      }
    );

    // ----- annotation store
    function loadStore() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}"); }
      catch (_) { return {}; }
    }
    function saveStore(s) { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); }
    function entryFor(kind, id) {
      var s = loadStore();
      return (s[kind] && s[kind][id]) || { notes: "", attachments: [] };
    }
    function setEntry(kind, id, val) {
      var s = loadStore();
      s[kind] = s[kind] || {};
      s[kind][id] = val;
      saveStore(s);
    }
    function annotatedIds(kind) {
      var s = loadStore()[kind] || {};
      return Object.keys(s).filter(function (k) {
        var v = s[k]; return (v.notes && v.notes.trim()) || (v.attachments && v.attachments.length);
      });
    }
    function isAnnotated(entry) {
      return !!((entry.notes && entry.notes.trim()) || (entry.attachments && entry.attachments.length));
    }

    function paintAnnotated() {
      annotatedIds("node").forEach(function (id) {
        try { nodes.update({ id: id, borderWidth: 4, color: { border: "#16a34a" } }); } catch (_) {}
      });
      annotatedIds("edge").forEach(function (id) {
        try { edges.update({ id: id, color: { color: "#16a34a", highlight: "#15803d" }, width: 3 }); } catch (_) {}
      });
    }
    paintAnnotated();

    // ----- side panel (DOM-built; no innerHTML for any data)
    var panelEmpty = document.getElementById("graph-empty");
    var panelDetail = document.getElementById("graph-detail");

    function clearChildren(el) { while (el.firstChild) el.removeChild(el.firstChild); }
    function el(tag, attrs, text) {
      var node = document.createElement(tag);
      if (attrs) Object.keys(attrs).forEach(function (k) {
        if (k === "class") node.className = attrs[k];
        else if (k === "style") node.setAttribute("style", attrs[k]);
        else node.setAttribute(k, attrs[k]);
      });
      if (text != null) node.textContent = text;
      return node;
    }
    function showEmpty() {
      panelEmpty.style.display = "";
      panelDetail.style.display = "none";
      clearChildren(panelDetail);
    }

    function renderAttachmentsList(listEl, kind, payload, entry) {
      clearChildren(listEl);
      (entry.attachments || []).forEach(function (att, i) {
        var fig = el("figure", { class: "att-row" });
        var img = el("img", { class: "panel-thumb", alt: "" });
        img.src = att.dataUrl; // dataURL is safe as src
        var cap = el("figcaption", { class: "att-cap" });
        cap.appendChild(el("span", null, att.name || "image"));
        var rm = el("button", { class: "att-remove", type: "button" }, "remove");
        rm.addEventListener("click", function () {
          var cur = entryFor(kind, payload.id);
          cur.attachments.splice(i, 1);
          setEntry(kind, payload.id, cur);
          renderDetail(kind, payload);
          paintAnnotated();
        });
        cap.appendChild(rm);
        fig.appendChild(img);
        fig.appendChild(cap);
        listEl.appendChild(fig);
      });
    }

    function renderDetail(kind, payload) {
      panelEmpty.style.display = "none";
      panelDetail.style.display = "";
      clearChildren(panelDetail);

      var entry = entryFor(kind, payload.id);
      var isEdge = kind === "edge";

      // header
      panelDetail.appendChild(el("div", { class: "panel-label" }, isEdge ? "Edge / relationship" : (payload.group || "node")));
      var h2 = el("h2", { class: "panel-h2" }, isEdge ? (payload.fromLabel + " → " + payload.toLabel) : payload.label);
      panelDetail.appendChild(h2);
      if (isEdge) {
        var rel = el("div", { class: "mt-2" });
        rel.appendChild(el("span", { class: "panel-relationship" }, payload.label || "(no label)"));
        panelDetail.appendChild(rel);
      } else if (payload.title) {
        panelDetail.appendChild(el("p", { class: "text-[13px] text-slate-700 mt-2 leading-6" }, payload.title));
      }

      // notes
      var notesSection = el("div", { class: "panel-section" });
      var notesHead = el("div", { class: "flex items-center justify-between" });
      notesHead.appendChild(el("div", { class: "panel-label" }, "Notes"));
      var pill = el("span", { class: "pill" + (isAnnotated(entry) ? " pill-saved" : "") }, isAnnotated(entry) ? "saved" : "empty");
      notesHead.appendChild(pill);
      notesSection.appendChild(notesHead);
      var ta = el("textarea", { class: "panel-textarea mt-2", placeholder: "Free-text annotation. Saves on blur." });
      ta.value = entry.notes || "";
      ta.addEventListener("blur", function () {
        var cur = entryFor(kind, payload.id);
        cur.notes = ta.value;
        setEntry(kind, payload.id, cur);
        var saved = isAnnotated(cur);
        pill.textContent = saved ? "saved" : "empty";
        pill.className = "pill" + (saved ? " pill-saved" : "");
        paintAnnotated();
      });
      notesSection.appendChild(ta);
      panelDetail.appendChild(notesSection);

      // attachments
      var attSection = el("div", { class: "panel-section" });
      attSection.appendChild(el("div", { class: "panel-label" }, "Attachments"));
      var fileEl = el("input", { type: "file", accept: "image/*", class: "panel-input mt-2" });
      attSection.appendChild(fileEl);
      attSection.appendChild(el("p", { class: "text-[11px] text-slate-500 mt-1" }, "Images up to ~250 KB persist in this browser only."));
      var listEl = el("div");
      attSection.appendChild(listEl);
      panelDetail.appendChild(attSection);
      renderAttachmentsList(listEl, kind, payload, entry);

      fileEl.addEventListener("change", function () {
        var f = fileEl.files && fileEl.files[0];
        if (!f) return;
        if (f.size > 250 * 1024) { alert("File is larger than 250 KB. Pick a smaller image for the demo."); fileEl.value = ""; return; }
        var reader = new FileReader();
        reader.onload = function () {
          var cur = entryFor(kind, payload.id);
          cur.attachments = (cur.attachments || []).concat([{ name: f.name, dataUrl: reader.result }]);
          setEntry(kind, payload.id, cur);
          renderDetail(kind, payload);
          paintAnnotated();
        };
        reader.readAsDataURL(f);
      });

      // identifier
      var idSection = el("div", { class: "panel-section" });
      idSection.appendChild(el("div", { class: "panel-label" }, "Identifier"));
      idSection.appendChild(el("div", { class: "font-mono text-[12px] text-slate-700 mt-1" }, kind + ":" + payload.id));
      panelDetail.appendChild(idSection);
    }

    // ----- click handling
    network.on("click", function (params) {
      if (params.nodes && params.nodes.length) {
        var n = nodes.get(params.nodes[0]);
        renderDetail("node", { id: n.id, label: n.label, group: n.group, title: n.title });
        return;
      }
      if (params.edges && params.edges.length) {
        var e = edges.get(params.edges[0]);
        var fromN = nodes.get(e.from);
        var toN = nodes.get(e.to);
        renderDetail("edge", {
          id: e.id, label: e.label,
          fromLabel: (fromN && fromN.label) || e.from,
          toLabel:   (toN && toN.label)   || e.to
        });
        return;
      }
      showEmpty();
    });

    // ----- toolbar
    document.getElementById("graph-fit").addEventListener("click", function () {
      network.fit({ animation: { duration: 600, easingFunction: "easeOutCubic" } });
    });
    var physicsBtn = document.getElementById("graph-physics");
    var physicsOn = true;
    physicsBtn.addEventListener("click", function () {
      physicsOn = !physicsOn;
      network.setOptions({ physics: { enabled: physicsOn } });
      physicsBtn.textContent = physicsOn ? "Pause physics" : "Resume physics";
    });
    document.getElementById("graph-clear").addEventListener("click", function () {
      if (!confirm("Clear all annotations on this device for this investigation?")) return;
      localStorage.removeItem(STORAGE_KEY);
      rawNodes.forEach(function (n) {
        var s = GROUP_STYLES[n.group] || { color: "#475569" };
        nodes.update({ id: n.id, borderWidth: 1.5, color: { background: s.color, border: "#0f172a" } });
      });
      rawEdges.forEach(function (e) {
        edges.update({ id: e.id, color: { color: "#94a3b8", highlight: "#0f172a" }, width: 1.5 });
      });
      showEmpty();
    });

    network.once("stabilizationIterationsDone", function () { network.fit(); });
  })();
</script>
