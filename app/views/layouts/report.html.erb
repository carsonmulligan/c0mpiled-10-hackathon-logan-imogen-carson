<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Investigation Summary Report" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Public+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= yield :head %>
    <style>
      .report-page { font-family: "Source Serif 4", Georgia, serif; color: #111; max-width: 8.5in; margin: 0 auto; background: white; padding: 0.9in 1in; box-shadow: 0 1px 0 rgba(0,0,0,.05); }
      .report-page h1, .report-page h2 { font-family: "Public Sans", sans-serif; }
      .report-meta dt { font-weight: 600; color: #334155; font-family: "Public Sans", sans-serif; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
      .report-meta dd { margin: 0 0 .35rem 0; font-family: "Public Sans", sans-serif; font-size: 14px; }
      .report-table { width: 100%; border-collapse: collapse; font-family: "Public Sans", sans-serif; font-size: 13px; }
      .report-table th, .report-table td { border-bottom: 1px solid #e2e8f0; padding: 8px 10px; text-align: left; vertical-align: top; }
      .report-table thead th { background: #f1f5f9; font-weight: 700; }
      .report-classification { background: #fef2f2; color: #7f1d1d; border: 1px solid #fecaca; padding: 6px 12px; font-family: "Public Sans", sans-serif; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; display: inline-block; }
      .report-fig { margin: 1.25rem 0; border: 1px solid #e2e8f0; padding: 8px; background: #fafafa; }
      .report-fig img { display: block; max-width: 100%; max-height: 360px; margin: 0 auto; }
      .report-fig figcaption { font-family: "Public Sans", sans-serif; font-size: 12px; color: #475569; text-align: center; margin-top: 8px; }
      @media print { body { background: white; } .report-page { box-shadow: none; padding: 0.5in; } .no-print { display: none !important; } }
    </style>
  </head>
  <body class="bg-slate-100 text-slate-900 antialiased">
    <%= yield %>
  </body>
</html>
